{
  "name": "trailverse-server",
  "version": "1.1.0",
  "description": "TrailVerse API - National Parks Explorer USA Backend",
  "main": "server.js",
  "scripts": {
    "start": "node --max-old-space-size=512 server.js",
    "dev": "nodemon --legacy-watch --watch server.js --watch src --ext js,mjs,cjs,json server.js",
    "seed": "node scripts/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:web-search": "jest src/services/__tests__/webSearchClassifier.test.js src/services/__tests__/factsWebSearchPolicy.test.js src/services/__tests__/factsWebSearch.live.test.js",
    "test:web-search:live": "node scripts/test-web-search-live.js",
    "test:web-search:full": "node scripts/test-web-search-live.js --full",
    "verify:trailie-live": "node scripts/verify-trailie-live-responses.js --save-report",
    "verify:plan-ai-flows": "node scripts/test-plan-ai-flows.js",
    "test:email": "node test-email-system.js",
    "test:email-simple": "node test-simple-email.js",
    "test:email-routes": "node test-email-routes.js",
    "setup:email": "node scripts/setup-email-system.js",
    "preview:email": "node preview-blog-email.js",
    "migrate:email": "node scripts/migrate-email-preferences.js",
    "bump:blog-views": "node scripts/bump-blog-views.js",
    "bump:blog-views:apply": "node scripts/bump-blog-views.js --apply",
    "bump:blog-recent": "node scripts/bump-recent-blog-views.js",
    "bump:blog-recent:apply": "node scripts/bump-recent-blog-views.js --apply"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@babel/core": "^7.28.4",
    "@babel/preset-react": "^7.27.1",
    "@babel/register": "^7.28.3",
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "mongoose": "^7.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^7.0.9",
    "openai": "^4.24.1",
    "resend": "^6.1.2",
    "sharp": "^0.34.4",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "unzipper": "^0.12.3",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.0.0",
    "validator": "^13.15.15"
  },
  "overrides": {
    "validator": "^13.15.15",
    "express-validator": {
      "validator": "^13.15.15"
    }
  }
}
