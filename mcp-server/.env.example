# TrailVerse backend URL (already deployed on Render)
TRAILVERSE_API_BASE=https://trailverse.onrender.com

# Where this MCP server is deployed (used for widget resource URIs)
MCP_SERVER_BASE=https://trailverse-mcp.onrender.com

# TrailVerse website URL for deep-link-back buttons
TRAILVERSE_WEB_BASE=https://www.nationalparksexplorerusa.com

# Markdown-only tool responses (recommended). ChatGPT HTML widgets are unreliable.
# Default true — full Trailie markdown in text blocks for all clients.
MCP_MARKDOWN_ONLY=true

# Re-enable HTML widgets + structuredContent (experimental; not recommended for ChatGPT).
# MCP_ENABLE_WIDGETS=true

# Port (Render sets this automatically)
PORT=8000

# Request timeout in seconds for read-tool backend calls (search, details, compare, events)
BACKEND_TIMEOUT=30

# Bounded timeout for plan_trip AI generation (returns controlled error instead of hanging)
PLAN_TRIP_TIMEOUT=30

# Optional: custom User-Agent when calling your backend
BACKEND_USER_AGENT=TrailVerse-MCP/1.0

# ---------- Rate limit bypass (REQUIRED for production) ----------
# Shared secret between this MCP server and the TrailVerse Express backend.
# Without it, all ChatGPT traffic flows through one IP and hits the anonymous
# 60 req/15min limit almost immediately. See server/middleware/mcpBypass.js
# on the TrailVerse backend for the corresponding check.
#
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Set the SAME value on:
#   - this MCP server (MCP_BYPASS_KEY)
#   - the TrailVerse Express backend (MCP_BYPASS_KEY)
MCP_BYPASS_KEY=

# ---------- In-MCP rate limits (defense-in-depth) ----------
# These cap total MCP → backend throughput regardless of who's calling.
# Fires a ceiling in case the bypass key ever leaks.
MCP_PLAN_TRIP_LIMIT=120    # AI planner calls per window
MCP_PLAN_TRIP_WINDOW=60    # seconds
MCP_READ_LIMIT=300         # park/search/events/compare calls per window
MCP_READ_WINDOW=60         # seconds
